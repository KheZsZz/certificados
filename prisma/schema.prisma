generator client {
  provider = "prisma-client"
  output   = "../src/generated"
}

datasource db {
  provider = "postgresql"
}

enum modality {
  ONLINE // online aulas ao vivo
  PRESENTIAL // presencial
  EAD // aulas gravadas
}

model Course {
  id                String             @id @default(uuid())
  name              String
  description       String
  workload          Int
  modality          modality           @default(EAD)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @default(now())
  foundationCourses FoundationCourse[]
  certificados  Certificado[]
}

model Foundation {
  id                String             @id @default(uuid())
  name              String
  document          String
  manager           String
  foundationCourses FoundationCourse[]
  certificados  Certificado[]
}

// Relacionamento entre Foundation e Course A:A
model FoundationCourse {
  id           String     @id @default(uuid())
  foundation_id String
  course_id     String

  foundation   Foundation @relation(fields: [foundation_id], references: [id])
  course       Course     @relation(fields: [course_id], references: [id])
}

enum roleUsers {
  DEVELOPERMENT
  ADM
  FINANCER
  SECRETARY
  TEACHER
  STUDENT
}

model User {
  id            String         @id @default(uuid())
  name          String
  email         String         @unique
  password      String
  phone         String
  role          roleUsers
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @default(now())
  refreshTokens RefreshToken[]
  certificados  Certificado[]
}

//Autenticação.
model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique // O hash do token ou o próprio token string
  expiresAt DateTime
  createdAt DateTime @default(now())
  user_id    String
  user      User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model Certificado {
  id          Int    @id @default(autoincrement())
  title       String
  description String
  workload    Int
  foundation_id  String
  course_id      String
  user_id      String
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  foundation  Foundation @relation(fields: [foundation_id], references: [id])
  course      Course     @relation(fields: [course_id], references: [id])
  user        User   @relation(fields: [user_id], references: [id])
}
